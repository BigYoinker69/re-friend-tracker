                        "name": "Family Name",
                        "width": 1,
                        "required": true
                    },
                    {
                        "id": "firstName",
                        "type": "text",
                        "name": "First Name",
                        "width": 1,
                        "required": true
                    },
                    {
                        "id": "nickname",
                        "type": "text",
                        "name": "Nickname",
                        "width": 2,
                        "required": true
                    },
                    {
